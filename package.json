{
    "name": "system-admin-scaffold",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n service,web -c blue,green \"bun run dev:service\" \"bun run dev:web\"",
        "dev:web": "vite",
        "dev:service": "bun --watch ./service/server.ts",
        "build": "bun run build:web && bun run build:service",
        "build:web": "vite build",
        "build:service": "bun build ./service/server.ts --target=bun --format=esm --minify --outdir=./dist",
        "start": "NODE_ENV=production bun dist/server.js",
        "lint": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@ant-design/cssinjs": "^2.1.2",
        "@ant-design/icons": "^6.1.1",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hono/node-server": "^1.19.14",
        "@tanstack/react-query": "^5.99.0",
        "antd": "^6.3.5",
        "axios": "^1.15.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.4.2",
        "framer-motion": "^12.38.0",
        "hono": "^4.12.12",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.22.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.1",
        "reflect-metadata": "^0.2.2",
        "tailwindcss": "^4.2.2",
        "typeorm": "^0.3.28",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vite-plugin-css-injected-by-js": "^4.0.1"
    }
}
